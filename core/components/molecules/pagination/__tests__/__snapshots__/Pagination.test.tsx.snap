exports[`Pagination component 
  type: "basic", page: 10, totalPages: 50, onPageChange: "[Function]"
 1`] = `
<DocumentFragment>
  <div
    class="Pagination Pagination--basic"
    data-test="DesignSystem-Pagination"
  >
    <div
      class="Pagination-buttonWrapper Pagination-buttonWrapper--previous"
    >
      <button
        aria-label="First page"
        class="Button Button--regular Button--regularSquare Button--transparent Pagination-button"
        data-test="DesignSystem-Pagination--FirstButton"
        tabindex="0"
      >
        <div
          class="Button-icon"
          data-test="DesignSystem-Button--Icon-Wrapper"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Button--Icon"
            style="font-size: 16px; width: 16px;"
          >
            first_page
          </i>
        </div>
      </button>
      <button
        aria-label="Previous page"
        class="Button Button--regular Button--regularSquare Button--basic ml-4 mr-3 Pagination-button"
        data-test="DesignSystem-Pagination--PrevButton"
        tabindex="0"
      >
        <div
          class="Button-icon"
          data-test="DesignSystem-Button--Icon-Wrapper"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Button--Icon"
            style="font-size: 16px; width: 16px;"
          >
            navigate_before
          </i>
        </div>
      </button>
    </div>
    <div
      class="Pagination-buttonWrapper Pagination-buttonWrapper--next"
    >
      <button
        aria-label="Next page"
        class="Button Button--regular Button--regularSquare Button--basic ml-3 mr-4 Pagination-button"
        data-test="DesignSystem-Pagination--NextButton"
        tabindex="0"
      >
        <div
          class="Button-icon"
          data-test="DesignSystem-Button--Icon-Wrapper"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Button--Icon"
            style="font-size: 16px; width: 16px;"
          >
            navigate_next
          </i>
        </div>
      </button>
      <button
        aria-label="Last page"
        class="Button Button--regular Button--regularSquare Button--transparent Pagination-button"
        data-test="DesignSystem-Pagination--LastButton"
        tabindex="0"
      >
        <div
          class="Button-icon"
          data-test="DesignSystem-Button--Icon-Wrapper"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Button--Icon"
            style="font-size: 16px; width: 16px;"
          >
            last_page
          </i>
        </div>
      </button>
    </div>
  </div>
</DocumentFragment>
`;

exports[`Pagination component 
  type: "jump", page: 10, totalPages: 50, onPageChange: "[Function]"
 1`] = `
<DocumentFragment>
  <div
    class="Pagination Pagination--jump"
    data-test="DesignSystem-Pagination"
  >
    <div
      class="Pagination-buttonWrapper Pagination-buttonWrapper--previous"
    >
      <button
        aria-label="First page"
        class="Button Button--regular Button--regularSquare Button--transparent Pagination-button"
        data-test="DesignSystem-Pagination--FirstButton"
        tabindex="0"
      >
        <div
          class="Button-icon"
          data-test="DesignSystem-Button--Icon-Wrapper"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
