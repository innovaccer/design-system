            data-test="DesignSystem-Button--Icon"
            style="font-size: 16px; width: 16px;"
          >
            navigate_before
          </i>
        </div>
      </button>
    </div>
    <div
      class="Pagination-pageIndex"
    >
      <div
        class="MetricInput MetricInput--regular Pagination-MetricInput"
        data-test="DesignSystem-MetricInputWrapper"
        role="presentation"
      >
        <button
          aria-label="Decrement value"
          class="MetricInput-arrowButton MetricInput-arrowIcons MetricInput-arrowButton--left"
          data-test="DesignSystem-MetricInput--downIcon"
          tabindex="-1"
          type="button"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Icon"
            style="font-size: 14px; width: 14px;"
          >
            keyboard_arrow_left
          </i>
        </button>
        <div
          class="MetricInput-content MetricInput-content--regular"
        >
          <input
            aria-describedby="DesignSystem-Pagination-totalPage-Test-uid"
            aria-label="Current page"
            class="MetricInput-input MetricInput-input--regular"
            data-test="DesignSystem-Pagination--Input"
            name="page"
            type="number"
            value="10"
          />
        </div>
        <button
          aria-label="Increment value"
          class="MetricInput-arrowButton MetricInput-arrowIcons MetricInput-arrowButton--right"
          data-test="DesignSystem-MetricInput--upIcon"
          tabindex="-1"
          type="button"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Icon"
            style="font-size: 14px; width: 14px;"
          >
            keyboard_arrow_right
          </i>
        </button>
      </div>
      <span
        class="Text Text--default Text--regular"
        data-test="DesignSystem-Text"
        id="DesignSystem-Pagination-totalPage-Test-uid"
      >
         of 50 pages
      </span>
    </div>
    <div
      class="Pagination-buttonWrapper Pagination-buttonWrapper--next"
    >
      <button
        aria-label="Next page"
        class="Button Button--regular Button--regularSquare Button--basic ml-3 mr-4 Pagination-button"
        data-test="DesignSystem-Pagination--NextButton"
        tabindex="0"
      >
        <div
          class="Button-icon"
          data-test="DesignSystem-Button--Icon-Wrapper"
        >
          <i
            class="material-symbols material-symbols-rounded Icon"
            data-test="DesignSystem-Button--Icon"
            style="font-size: 16px; width: 16px;"
          >
            navigate_next
          </i>
        </div>
      </button>
      <button
        aria-label="Last page"
        class="Button Button--regular Button--regularSquare Button--transparent Pagination-button"
        data-test="DesignSystem-Pagination--LastButton"
        tabindex="0"
      >
        <div
