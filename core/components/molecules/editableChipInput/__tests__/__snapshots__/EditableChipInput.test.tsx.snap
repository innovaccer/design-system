exports[`EditableChipInput component 
  placeholder: "Add Value", disableSaveAction: false, value: ["Chip1","Chip2"], chipInputOptions: {"chipOptions":{"onClick":"[Function]","maxWidth":"256px","clearButton":true},"allowDuplicates":false,"defaultValue":[],"autoFocus":true}
 1`] = `
<DocumentFragment>
  <div
    aria-label="Click to edit. Current chips: Chip1, Chip2"
    class="EditableChipInput"
    data-test="DesignSystem-EditableChipInput"
    role="button"
    tabindex="0"
  >
    <div
      class="Editable"
      data-test="DesignSystem-Editable"
    >
      <div
        data-test="DesignSystem-EditableWrapper"
      >
        <div
          class="EditableChipInput-defaultWithChips"
          data-test="DesignSystem-EditableChipInput--Default"
        >
          <div
            aria-label="Chip1"
            class="Chip-wrapper Chip Chip--input Chip-icon--clear Chip-size--regular EditableChipInput-chip--regular"
            data-test="DesignSystem-EditableChipInput--Chip"
            role="button"
            style="max-width: 256px;"
            tabindex="0"
          >
            <div
              class="Chip-text--truncate"
            >
              <span
                class="Text Text--regular color-inverse Chip-text"
                data-test="DesignSystem-GenericChip--Text"
              >
                Chip1
              </span>
            </div>
            <div
              aria-label="Remove Chip1"
              class="Chip-icon Chip-icon--right cursor-pointer p-3"
              data-test="DesignSystem-GenericChip--clearButton"
              role="button"
              tabindex="0"
            >
              <i
                class="material-symbols material-symbols-rounded Icon Icon--subtle"
                data-test="DesignSystem-Icon"
                style="font-size: 16px; width: 16px;"
              >
                clear
              </i>
            </div>
          </div>
          <div
            aria-label="Chip2"
            class="Chip-wrapper Chip Chip--input Chip-icon--clear Chip-size--regular EditableChipInput-chip--regular"
            data-test="DesignSystem-EditableChipInput--Chip"
            role="button"
            style="max-width: 256px;"
            tabindex="0"
          >
            <div
              class="Chip-text--truncate"
            >
              <span
                class="Text Text--regular color-inverse Chip-text"
                data-test="DesignSystem-GenericChip--Text"
              >
                Chip2
              </span>
            </div>
            <div
              aria-label="Remove Chip2"
              class="Chip-icon Chip-icon--right cursor-pointer p-3"
              data-test="DesignSystem-GenericChip--clearButton"
              role="button"
              tabindex="0"
            >
              <i
                class="material-symbols material-symbols-rounded Icon Icon--subtle"
                data-test="DesignSystem-Icon"
                style="font-size: 16px; width: 16px;"
              >
                clear
              </i>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</DocumentFragment>
`;

